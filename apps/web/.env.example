
# URL pública do PocketBase em produção (Fly.io).
# Em dev local, use http://localhost:8090
VITE_POCKETBASE_URL=http://localhost:8090

# Não é usado pelo PocketBase 0.23+ (não há anon key). Mantido por compat.
VITE_POCKETBASE_ANON_KEY=

# AdSense (publisher id) — opcional.
VITE_ADSENSE_CLIENT=

# Hotmart checkout URL.
VITE_HOTMART_URL=

# Cloudflare Worker que roda Vision SafeSearch para moderar imagens.
# Vazio = pular moderação NSFW (uploads ainda passam por MIME/tamanho).
VITE_NSFW_WORKER_URL=
