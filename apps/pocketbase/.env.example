# ────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do backend PocketBase.
# Em produção (Fly.io) usar: flyctl secrets set CHAVE=valor
# ────────────────────────────────────────────────────────────────────

# Criptografia do banco SQLite. Gere com:  openssl rand -hex 32
# OBRIGATÓRIA — sem ela o flag --encryptionEnv=PB_ENCRYPTION_KEY falha.
PB_ENCRYPTION_KEY=

# OpenAI Moderation API (gratuita). Obtenha em:
#   https://platform.openai.com/api-keys
# Sem essa chave o hook de moderação bloqueia 100% das mensagens (fail-closed).
OPENAI_API_KEY=

# Opcionais — override de comportamento de moderação:
# OPENAI_MOD_MODEL=omni-moderation-latest
# MOD_STRICT_THRESHOLD=0.50
# MOD_MAX_STRIKES=3

# Opcionais — override de rate limits:
# RL_CHAT_MAX=10
# RL_CHAT_WINDOW=60
# RL_POST_MAX=3
# RL_POST_WINDOW=300
# RL_REPLY_MAX=15
# RL_REPLY_WINDOW=300
# RL_COMMENT_MAX=5
# RL_COMMENT_WINDOW=300
